package components

type BreadcrumbItem struct {
	Label string
	URL   string
	Active bool
}

templ Breadcrumbs(items []BreadcrumbItem) {
	<div class="text-sm breadcrumbs mb-6">
		<ul>
			for _, item := range items {
				if item.Active {
					<li><span class="font-bold">{ item.Label }</span></li>
				} else {
					<li><a href={ templ.SafeURL(item.URL) }>{ item.Label }</a></li>
				}
			}
		</ul>
	</div>
}
