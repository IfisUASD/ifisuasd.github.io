@article{perez2023neutrinos,
  title     = {Neutrino detection in the UASD telescope},
  doi       = {10.1234/physrev.2023.1234},
  author    = {Pérez, V. and Sánchez, A.},
  journal   = {Journal of Particle Physics},
  year      = {2023},
  volume    = {12},
  abstract  = {We present the first systematic study of neutrino detection capabilities using the UASD telescope facility. Our analysis demonstrates that the telescope can effectively identify neutrino interactions with cosmic ray showers, achieving a detection efficiency of 87%. This work establishes a baseline for future neutrino astronomy programs in the Caribbean region and opens new opportunities for multi-messenger astrophysics research.},
  x-orcids  = {0000-0001-2345-6789,0000-0002-9876-5432},
  x-project = {FONDOCYT-2024-01}
}

@article{sanchez2024supernova,
  title     = {Observations of Supernovae in the Andean Sky},
  doi       = {10.1234/astro.2024.5678},
  author    = {Sánchez, A. and Pérez, V.},
  journal   = {Astrophysical Journal},
  year      = {2024},
  volume    = {34},
  abstract  = {This paper reports on a comprehensive survey of Type Ia supernovae observed from high-altitude sites in the Andes mountains. We present photometric and spectroscopic data for 23 supernovae discovered during our 18-month campaign. Our results show evidence for previously unreported dust extinction patterns that may affect standardization of these objects as cosmological distance indicators. The implications for dark energy measurements are discussed.},
  x-orcids  = {0000-0002-9876-5432,0000-0001-2345-6789},
  x-project = {MESCYT-2024-02}
}
